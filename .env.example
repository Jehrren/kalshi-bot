# Kalshi API Key ID (UUID aus dem Kalshi-Account)
KALSHI_API_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Kalshi RSA Private Key (PEM-Format, einzeilig mit \n getrennt)
# Tipp: cat private_key.pem | tr '\n' '|' → dann | durch \n ersetzen
# Oder: mehrzeilig mit Anführungszeichen in der .env
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
DEIN_PRIVATE_KEY_HIER
-----END RSA PRIVATE KEY-----"

# Loglevel: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
